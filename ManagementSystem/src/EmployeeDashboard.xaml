<Window x:Class="Employee_Management_System.EmployeeDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Dashboard" Height="650" Width="1350" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" AllowsTransparency="False">
    
    <Grid>
        <!-- Define the column structure of the main grid -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>  <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar Panel -->
        <StackPanel Grid.Column="0" Background="#2C3E50" Width="200" VerticalAlignment="Stretch" Margin="10">
            <!-- Sidebar Buttons -->
            <Button Content="Clock In" Margin="5" Height="40" Background="#34495E" Foreground="White" Click="ClockIn_Click"/>
            <Button Content="Clock Out" Margin="5" Height="40" Background="#34495E" Foreground="White" Click="ClockOut_Click"/>
            <Button Content="View Attendance Logs" Margin="5" Height="40" Background="#34495E" Foreground="White" Click="ViewAttendanceLogs_Click"/>
            <Button Content="Logout" Margin="5" Height="40" Background="#34495E" Foreground="White" Click="Logout_Click"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="10">
            <!-- Define the row structure of the main content grid -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Border BorderBrush="Black" BorderThickness="2" Margin="2" CornerRadius="5" Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Background="Black">
                    <!-- Welcome Text -->
                    <TextBlock Text="Welcome to Employee Dashboard" 
                               FontSize="28" FontWeight="Bold" Foreground="#34495E"
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    <!-- Digital Clock -->
                    <TextBlock x:Name="txtClock" FontSize="28" FontWeight="Bold" Foreground="#34495E"
                               HorizontalAlignment="Right" Margin="30,20,0,0"/>
                </StackPanel>
            </Border>

            <!-- Bottom-Left "Health Records" Button -->
            <Button Content="Health Records" Margin="10" Height="40" Width="200" Background="Blue" Foreground="White" 
                    Click="HealthRecords_Click" Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
        </Grid>
    </Grid>
</Window>